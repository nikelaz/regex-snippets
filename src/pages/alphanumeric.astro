---
import Layout from '../layouts/Layout.astro';
import AlphanumericPage from '../components/pages/AlphanumericPage';
import { pagesMetadata, generateHowToJsonLd } from '../lib/seo';

const meta = pagesMetadata['alphanumeric'];
const jsonLd = generateHowToJsonLd('alphanumeric');
---

<Layout
  title={meta.title}
  description={meta.description}
  keywords={meta.keywords}
  path={meta.path}
  jsonLd={jsonLd ?? undefined}
>
  <AlphanumericPage client:load />
</Layout>
