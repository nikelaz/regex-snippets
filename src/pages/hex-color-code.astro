---
import Layout from '../layouts/Layout.astro';
import HexColorPage from '../components/pages/HexColorPage';
import { pagesMetadata, generateHowToJsonLd } from '../lib/seo';

const meta = pagesMetadata['hex-color-code'];
const jsonLd = generateHowToJsonLd('hex-color-code');
---

<Layout
  title={meta.title}
  description={meta.description}
  keywords={meta.keywords}
  path={meta.path}
  jsonLd={jsonLd ?? undefined}
>
  <HexColorPage client:load />
</Layout>
