---
import Layout from '../layouts/Layout.astro';
import NumberOfLinesPage from '../components/pages/NumberOfLinesPage';
import { pagesMetadata, generateHowToJsonLd } from '../lib/seo';

const meta = pagesMetadata['number-of-lines'];
const jsonLd = generateHowToJsonLd('number-of-lines');
---

<Layout
  title={meta.title}
  description={meta.description}
  keywords={meta.keywords}
  path={meta.path}
  jsonLd={jsonLd ?? undefined}
>
  <NumberOfLinesPage client:load />
</Layout>
