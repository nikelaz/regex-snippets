---
import Layout from '../layouts/Layout.astro';
import UsernamePage from '../components/pages/UsernamePage';
import { pagesMetadata, generateHowToJsonLd } from '../lib/seo';

const meta = pagesMetadata['username'];
const jsonLd = generateHowToJsonLd('username');
---

<Layout
  title={meta.title}
  description={meta.description}
  keywords={meta.keywords}
  path={meta.path}
  jsonLd={jsonLd ?? undefined}
>
  <UsernamePage client:load />
</Layout>
