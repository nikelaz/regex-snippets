---
import Layout from '../layouts/Layout.astro';
import PasswordPage from '../components/pages/PasswordPage';
import { pagesMetadata, generateHowToJsonLd } from '../lib/seo';

const meta = pagesMetadata['password'];
const jsonLd = generateHowToJsonLd('password');
---

<Layout
  title={meta.title}
  description={meta.description}
  keywords={meta.keywords}
  path={meta.path}
  jsonLd={jsonLd ?? undefined}
>
  <PasswordPage client:load />
</Layout>
