---
import Layout from '../layouts/Layout.astro';
import DatePage from '../components/pages/DatePage';
import { pagesMetadata, generateHowToJsonLd } from '../lib/seo';

const meta = pagesMetadata['date'];
const jsonLd = generateHowToJsonLd('date');
---

<Layout
  title={meta.title}
  description={meta.description}
  keywords={meta.keywords}
  path={meta.path}
  jsonLd={jsonLd ?? undefined}
>
  <DatePage client:load />
</Layout>
