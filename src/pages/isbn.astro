---
import Layout from '../layouts/Layout.astro';
import ISBNPage from '../components/pages/ISBNPage';
import { pagesMetadata, generateHowToJsonLd } from '../lib/seo';

const meta = pagesMetadata['isbn'];
const jsonLd = generateHowToJsonLd('isbn');
---

<Layout
  title={meta.title}
  description={meta.description}
  keywords={meta.keywords}
  path={meta.path}
  jsonLd={jsonLd ?? undefined}
>
  <ISBNPage client:load />
</Layout>
